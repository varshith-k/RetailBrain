{
  "id": null,
  "uid": "retailbrain-observability",
  "title": "RetailBrain Observability",
  "tags": ["retailbrain", "monitoring"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "5s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Kafka Consumer Lag",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum by (partition) (kafka_consumer_lag)",
          "legendFormat": "partition {{partition}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Event Processing Latency p95",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(event_processing_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "API Latency p95 (by endpoint)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(api_request_latency_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Anomaly Rate (per minute)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "anomaly_rate_per_minute",
          "legendFormat": "anomalies/min",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Anomalies Detected Total (by type)",
      "gridPos": {"h": 8, "w": 16, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "anomalies_detected_total",
          "legendFormat": "{{alert_type}} — {{severity}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total Anomalies (all time)",
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 16},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(anomalies_detected_total)",
          "legendFormat": "total",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Purchase Drops",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 20},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "anomalies_detected_total{alert_type=\"purchase_drop\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Abandonment Spikes",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 20},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "anomalies_detected_total{alert_type=\"abandonment_spike\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": {"list": []},
  "time": {"from": "now-30m", "to": "now"}
}
